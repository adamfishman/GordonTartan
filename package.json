{
  "name": "gordon-tartan",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "dev:wrangler": "wrangler dev",
    "build": "node scripts/build-search-index.js && astro build",
    "seed": "node scripts/seed-d1.js",
    "deploy": "npm run build && wrangler d1 migrations apply gordon-tartan-db --remote && wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/cloudflare": "^13.1.1",
    "@astrojs/react": "^4.2.0",
    "@fontsource/alfa-slab-one": "^5.0.0",
    "@fontsource/barlow": "^5.0.0",
    "@fontsource/comfortaa": "^5.2.8",
    "@fontsource/medievalsharp": "^5.2.8",
    "astro": "^5.18.0",
    "lunr": "^2.3.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/lunr": "^2.3.7",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "happy-dom": "^20.7.0",
    "vitest": "^4.0.18",
    "wrangler": "^4.71.0"
  }
}
