---
import Layout from '../layouts/Layout.astro';
import SvgBg from '../components/SvgBg.astro';

// Gordon Dress tartan for hero background
const palette = 'W#E0E0E0 K#101010 G#005020 Y#E8C000 R#C80000 B#003C64';
const threadcount = 'G/36 K2 G4 K16 B16 K2 B2 K2 B16 W4 Y/4';
---
<Layout title="5k+ Tartan Patterns" description="Browse over 5000 official tartans from the Scottish Register, or create your own. Download seamless tiles in SVG and PNG format." tartanThreadcount={threadcount} tartanPalette={palette}>
  <SvgBg threadcount={threadcount} palette={palette} />
  <section class="etiquette section-page section-home">
    <header>
      <h1>
        Explore & Create{" "}
        <span class="title-font letter">Tartan Patterns</span>
      </h1>
      <p>
        Over 5,000 tartans from the Scottish Register of Tartans — browse, download, and use as seamless SVG and PNG tiles.
      </p>
      <p>
        Or start from any pattern and make it your own with the built-in editor.
      </p>
    </header>
    <div class="home-actions">
      <a class="home-btn home-btn-primary" href="/tartans/a">Browse A-Z</a>
      <a class="home-btn home-btn-secondary" href="/random">Random Tartan</a>
    </div>
    <div class="home-links">
      <a class="underlined-link" href="/about">About this project</a>
      <span class="home-links-sep">&middot;</span>
      <a class="underlined-link" href="/terms-of-use">Terms of use</a>
    </div>
  </section>
</Layout>
