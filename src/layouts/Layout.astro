---
import { ClientRouter } from 'astro:transitions';
import '@fontsource/barlow';
import '@fontsource/alfa-slab-one';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AZ from '../components/AZ.astro';

import SearchWidget from '../components/SearchWidget';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Gordon Tartan', description = 'Tartan Patterns Collection. Over 5000 tartan patterns in SVG and PNG format.' } = Astro.props;
const siteTitle = 'Gordon Tartan';
const fullTitle = title !== siteTitle ? `${title} | ${siteTitle}` : siteTitle;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <ClientRouter />
  </head>
  <body>
    <SearchWidget client:idle />
    <main class="wrapper">
      <Header />
      <div class="content">
        <slot />
      </div>
      <Footer />
    </main>
    <div class="sidebar">
      <nav>
        <AZ />
      </nav>
    </div>
  </body>
</html>
