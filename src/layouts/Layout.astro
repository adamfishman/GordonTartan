---
import { ClientRouter } from 'astro:transitions';
import '@fontsource/barlow';
import '@fontsource/alfa-slab-one';
import '@fontsource/comfortaa';
import '@fontsource/comfortaa/700.css';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AZ from '../components/AZ.astro';
import { getTitleColors } from '../lib/tartan';

import SearchWidget from '../components/SearchWidget';

interface Props {
  title?: string;
  description?: string;
  tartanThreadcount?: string;
  tartanPalette?: string;
}

const { title = 'Gordon Tartan', description = 'Tartan Patterns Collection. Over 5000 tartan patterns in SVG and PNG format.', tartanThreadcount, tartanPalette } = Astro.props;
const siteTitle = 'Gordon Tartan';
const fullTitle = title !== siteTitle ? `${title} | ${siteTitle}` : siteTitle;

const titleColors =
  tartanThreadcount && tartanPalette
    ? getTitleColors(tartanThreadcount, tartanPalette)
    : null;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link href="https://fonts.cdnfonts.com/css/ocie" rel="stylesheet" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <ClientRouter />
  </head>
  <body>
    <SearchWidget client:idle />
    <main class="wrapper">
      <Header titleFill={titleColors?.fill} titleBorder={titleColors?.border} />
      <div class="content">
        <slot />
      </div>
      <Footer />
    </main>
    <div class="sidebar">
      <nav>
        <AZ />
      </nav>
    </div>
  </body>
</html>
