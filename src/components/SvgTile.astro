---
import SvgDefs from './SvgDefs.astro';
import { countPattern } from '../lib/tartan';

interface Props {
  palette: string;
  threadcount: string;
}

const { palette, threadcount } = Astro.props;
const tartanCount = countPattern(threadcount, palette);

const cumulativeSizes: number[] = [];
let sum = 0;
for (const entry of tartanCount) {
  sum += entry.size;
  cumulativeSizes.push(sum);
}

const size = cumulativeSizes[cumulativeSizes.length - 1];
---
<svg
  viewBox={`0 0 ${size} ${size}`}
  width={size}
  height={size}
  x="0"
  y="0"
  xmlns="http://www.w3.org/2000/svg"
>
  <SvgDefs />
  <g id="horizStripes">
    {tartanCount.map((el, index) => (
      <rect
        fill={el.fill}
        height={el.size}
        width="100%"
        x="0"
        y={cumulativeSizes[index - 1] || 0}
      />
    ))}
  </g>
  <g id="vertStripes" mask="url(#grating)">
    {tartanCount.map((el, index) => (
      <rect
        fill={el.fill}
        height="100%"
        width={el.size}
        x={cumulativeSizes[index - 1] || 0}
        y="0"
      />
    ))}
  </g>
</svg>
