---
import Info from './Info.astro';
import TartanNavigation from './TartanNavigation.astro';
import { buildOriginUrl } from '../lib/tartan';

interface Props {
  name: string;
  refId: number | null;
  previous: { slug: string; name: string } | null;
  next: { slug: string; name: string } | null;
}

const { name, refId, previous, next } = Astro.props;
const originURL = buildOriginUrl(refId);
---
<div class="info">
  <h1 class="title-font etiquette">
    <span>{name}</span>
    {originURL && <Info class="info-icon" url={originURL} />}
  </h1>
  <TartanNavigation previous={previous} next={next} refId={refId} />
</div>
